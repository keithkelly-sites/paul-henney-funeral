---
/**
 * Contact — Paul Henney Cremation & Funeral Tributes
 * Immediate support info, location, directions.
 */
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import mapImg from '../assets/images/map.png';
---
<Layout title="Contact Us | Paul Henney Cremation & Funeral Tributes" activePage="contact" description="Contact Paul Henney Cremation & Funeral Tributes at (412) 835-1312. 5570 Library Road, Bethel Park, PA 15102. Available 24/7.">

<section class="contact-hero">
  <div class="contact-hero-inner">
    <span class="contact-hero-label">Contact Us</span>
    <h1 class="contact-hero-title">We're Here<br />For You</h1>
    <p class="contact-hero-sub">Any time of day, any day of the week.</p>
    <div class="contact-hero-line"></div>
  </div>
</section>

<section class="contact-main reveal">
  <div class="contact-main-inner">

    <div class="contact-info">
      <div class="contact-block contact-block-phone">
        <h2>For Immediate Support</h2>
        <a href="tel:4128351312" class="phone-large">(412) 835-1312</a>
        <p>Available 24 hours a day, 7 days a week. You are welcome to call us any time for immediate assistance.</p>
      </div>

      <div class="contact-block">
        <h3>Visit Us</h3>
        <address>
          Paul Henney Cremation and Funeral Tributes Inc.<br />
          5570 Library Road<br />
          Bethel Park, PA 15102
        </address>
      </div>

      <div class="contact-block">
        <h3>Office Hours</h3>
        <p>Our office staff is available to assist you during regular business hours. For immediate need after hours, please call the number above.</p>
      </div>
    </div>

    <div class="contact-map" id="directions">
      <a href="https://www.google.com/maps/dir/?api=1&destination=5570+Library+Road+Bethel+Park+PA+15102"
         target="_blank" rel="noopener noreferrer" class="map-link">
        <Image src={mapImg} alt="Map showing Paul Henney Cremation & Funeral Tributes location at 5570 Library Road, Bethel Park, PA" loading="lazy" width={800} height={500} class="map-image" />
        <div class="map-bar">
          <span>5570 Library Road, Bethel Park</span>
          <span class="map-dir">Get directions &rarr;</span>
        </div>
      </a>
    </div>

  </div>
</section>

<section class="contact-note reveal">
  <div class="contact-note-inner">
    <p>You can also visit our funeral home to discuss your needs in person. Whether you're planning ahead or need immediate assistance, our staff is here to guide you through every step with patience and care.</p>
  </div>
</section>

</Layout>

<style>
  .contact-hero {
    min-height: 55vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-3xl) var(--space-lg) var(--space-2xl);
    background: radial-gradient(ellipse at 50% 80%, var(--color-amber-glow), transparent 60%);
  }

  .contact-hero-label {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-amber);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: var(--space-md);
  }

  .contact-hero-title {
    font-family: var(--font-display), Georgia, serif;
    font-size: var(--font-size-hero);
    font-weight: 300;
    line-height: 0.95;
    color: var(--color-cream);
    letter-spacing: -0.02em;
  }

  .contact-hero-sub {
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
    margin-top: var(--space-md);
  }

  .contact-hero-line {
    width: 60px;
    height: 1px;
    background: var(--color-amber);
    margin: var(--space-lg) auto 0;
  }

  /* Main layout */
  .contact-main {
    padding: var(--space-2xl) var(--space-lg);
  }

  .contact-main-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .contact-main-inner {
      grid-template-columns: 1fr 1.3fr;
    }
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .contact-block h2 {
    font-family: var(--font-display), Georgia, serif;
    font-size: var(--font-size-lg);
    font-weight: 400;
    color: var(--color-cream);
    margin-bottom: var(--space-sm);
  }

  .contact-block h3 {
    font-family: var(--font-display), Georgia, serif;
    font-size: var(--font-size-md);
    font-weight: 500;
    color: var(--color-amber);
    margin-bottom: var(--space-xs);
    letter-spacing: 0.02em;
  }

  .phone-large {
    display: block;
    font-family: var(--font-display), Georgia, serif;
    font-size: var(--font-size-2xl);
    font-weight: 500;
    color: var(--color-amber);
    margin-bottom: var(--space-sm);
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .phone-large:hover {
    opacity: 0.8;
  }

  .contact-block p,
  .contact-block address {
    color: var(--color-text-muted);
    font-style: normal;
    line-height: 1.8;
    font-size: var(--font-size-base);
  }

  /* Map */
  .contact-map {
    border-radius: var(--border-radius);
    overflow: hidden;
    border: 1px solid oklch(1 0 0 / 0.06);
  }

  .map-link {
    display: block;
    text-decoration: none;
    position: relative;
  }

  .map-image {
    width: 100%;
    height: auto;
    display: block;
    transition: filter 0.3s ease;
  }

  .map-link:hover .map-image {
    filter: brightness(1.1);
  }

  .map-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-card);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .map-dir {
    color: var(--color-amber);
    white-space: nowrap;
  }

  /* Note */
  .contact-note {
    padding: var(--space-xl) var(--space-lg) var(--space-2xl);
  }

  .contact-note-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    text-align: center;
  }

  .contact-note-inner p {
    color: var(--color-text-muted);
    line-height: 1.8;
    font-size: var(--font-size-base);
  }
</style>
