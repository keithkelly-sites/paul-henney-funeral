---
/**
 * Homepage — Paul Henney Cremation & Funeral Tributes
 *
 * Design concept: Inspired by luxury memorial sites and museum exhibition pages
 * that treat reverence as visual drama, not visual silence. The candlelight ceremony
 * photo becomes the emotional anchor — "Celebrate Life" in massive Cormorant Garamond
 * floats over warm amber glow, creating a quiet moment of awe before the page unfolds.
 * Dark charcoal backgrounds with amber candlelight accents throughout. Each section
 * reveals on scroll like turning pages in a memory book.
 *
 * Reference: The spatial pacing and typographic scale of fc-porto-memorial (Awwwards SOTD),
 * the warm darkness and candlelight color strategy of luxury hotel sites like Aman,
 * the scroll-reveal storytelling of editorial longform pieces.
 */
import Layout from '../layouts/Layout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FuneralHome",
  "name": "Paul Henney Cremation and Funeral Tributes Inc.",
  "url": "https://paul-henney-funeral.keithkelly.dev",
  "telephone": "+1-412-835-1312",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "5570 Library Road",
    "addressLocality": "Bethel Park",
    "addressRegion": "PA",
    "postalCode": "15102",
    "addressCountry": "US"
  },
  "description": "Serving Bethel Park and surrounding communities since 1916. Personalized cremation and funeral tributes that celebrate life.",
  "foundingDate": "1916"
};
---
<Layout title="Paul Henney Cremation & Funeral Tributes | Bethel Park, PA" activePage="home" description="Serving Bethel Park and surrounding communities since 1916. Personalized cremation and funeral tributes that celebrate life.">

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<!-- HERO — the signature moment -->
<section class="hero">
  <div class="hero-bg">
    <img src="/images/chapel_of_mem1.jpg" alt="" aria-hidden="true" class="hero-bg-img" />
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-content">
    <div class="hero-text">
      <h1 class="hero-title">
        <span class="hero-title-line hero-title-line-1">Celebrate</span>
        <span class="hero-title-line hero-title-line-2">Life</span>
      </h1>
      <div class="hero-divider"></div>
      <p class="hero-tagline">Serving families in Bethel Park since 1916</p>
    </div>
  </div>
  <div class="hero-scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- INTRODUCTION -->
<section class="intro reveal">
  <div class="intro-inner">
    <p class="intro-lead">Paul Henney Cremation & Funeral Tributes has become the place where meaningful funerals are an everyday occurrence.</p>
    <p class="intro-body">We take great time and effort during arrangements to learn about your loved one, their family and friends, and what was important in their life. From there, a personalized and fitting tribute is designed to celebrate the life lived.</p>
    <a href="/about" class="intro-link">Our story since 1916 &rarr;</a>
  </div>
</section>

<!-- SERVICES PREVIEW -->
<section class="services-preview">
  <div class="services-preview-header reveal">
    <span class="section-label">What We Offer</span>
    <h2 class="section-title">Thoughtful Services,<br />Thoughtfully Priced</h2>
  </div>

  <div class="services-cards">
    <div class="service-card reveal">
      <div class="service-card-image">
        <img src="/images/987238-funeral-fs-600x450-26.jpg" alt="Floral arrangement for burial tribute" loading="lazy" />
      </div>
      <div class="service-card-body">
        <h3>Burial Tributes</h3>
        <p>Traditional funeral services with viewing, honoring your loved one with dignity and personal touches that tell their story.</p>
        <span class="service-card-price">From $5,640</span>
      </div>
    </div>

    <div class="service-card reveal">
      <div class="service-card-image">
        <img src="/images/778156-urnwreathwhiteyellow.jpg" alt="Cremation urn with floral wreath" loading="lazy" />
      </div>
      <div class="service-card-body">
        <h3>Cremation</h3>
        <p>Traditional and contemporary cremation options, each designed to give families the space and time they need to gather, grieve, and heal.</p>
        <span class="service-card-price">Multiple options</span>
      </div>
    </div>

    <div class="service-card reveal">
      <div class="service-card-image">
        <img src="/images/442122-1-our-services.jpg" alt="Family planning personalized funeral service" loading="lazy" />
      </div>
      <div class="service-card-body">
        <h3>Personalized Tributes</h3>
        <p>Online memorials, tribute videos, and custom ceremonies that reflect the unique life of your loved one.</p>
        <span class="service-card-price">Included with services</span>
      </div>
    </div>
  </div>

  <div class="services-cta reveal">
    <a href="/services" class="cta-button">View All Services</a>
  </div>
</section>

<!-- TESTIMONIAL PULL QUOTE -->
<section class="pull-quote reveal">
  <div class="pull-quote-inner">
    <div class="pull-quote-mark">&ldquo;</div>
    <blockquote>
      <p>When my son passed, it felt like they took me by the hand and guided me gently through all that you must endure. They were kind, gentle, patient, loving and professional. They felt like family at a time when you need your family around you.</p>
    </blockquote>
    <cite>Anna Marie Newcomer</cite>
  </div>
</section>

<!-- WHAT SETS US APART -->
<section class="apart reveal">
  <div class="apart-inner">
    <span class="section-label">Why Families Choose Us</span>
    <h2 class="section-title">More Than a Service.<br />A Promise.</h2>

    <div class="apart-grid">
      <div class="apart-item">
        <span class="apart-number">01</span>
        <h3>Personal Attention</h3>
        <p>We take time to learn about the life lived. Every detail of the service reflects the person being honored, not a formula.</p>
      </div>
      <div class="apart-item">
        <span class="apart-number">02</span>
        <h3>Aftercare</h3>
        <p>Our staff meets personally with every family after the funeral to help with the administrative tasks and emotional transition ahead.</p>
      </div>
      <div class="apart-item">
        <span class="apart-number">03</span>
        <h3>Grief Support</h3>
        <p>A year of daily grief support emails for every family we serve. Our care doesn't end when the service does.</p>
      </div>
      <div class="apart-item">
        <span class="apart-number">04</span>
        <h3>Four Generations</h3>
        <p>The Henney name in funeral service traces back to 1916. This work isn't just our profession, it's our family's calling.</p>
      </div>
    </div>
  </div>
</section>

<!-- TEAM PREVIEW -->
<section class="team-preview reveal">
  <div class="team-preview-inner">
    <div class="team-image-col">
      <img src="/images/546435-unnamed3.jpg" alt="Paul Henney, Marie Wohlgemuth, and Allina Varner" loading="lazy" />
    </div>
    <div class="team-text-col">
      <span class="section-label">Our Team</span>
      <h2>Here for You,<br />Every Step</h2>
      <p>Paul Henney, Marie Wohlgemuth, and Allina Varner bring decades of combined experience and genuine compassion to every family they serve. They're not just professionals. They become your advocates during the most difficult days.</p>
      <a href="/about#staff" class="cta-link-arrow">Meet our staff &rarr;</a>
    </div>
  </div>
</section>

<!-- CONTACT CTA -->
<section class="home-cta reveal">
  <div class="home-cta-inner">
    <h2>Available 24 hours a day,<br />7 days a week.</h2>
    <a href="tel:4128351312" class="cta-phone">(412) 835-1312</a>
    <div class="cta-address">
      <p>5570 Library Road, Bethel Park, PA 15102</p>
      <a href="/contact" class="cta-link-arrow">Contact us &rarr;</a>
    </div>
  </div>
</section>

</Layout>

<style>
